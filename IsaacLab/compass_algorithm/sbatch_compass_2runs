#!/bin/bash
# ==============================================================================
# P2P-SAC Algorithm Training Script (DUAL RUN, SINGLE GPU)
# ==============================================================================
#SBATCH --account=naiss2025-22-1453
#SBATCH --partition=alvis
#SBATCH --gpus-per-node=T4:1  # <--- Back to 1 GPU
#SBATCH --time=7-00:00:00
#SBATCH --job-name=COMPASS_Go2_SharedGPU
#SBATCH --output=slurm_logs/compass_shared_%j.out
#SBATCH --error=slurm_logs/compass_shared_%j.err
#SBATCH --mail-type=END,FAIL
# ==============================================================================

set -e
echo "[$(date '+%Y-%m-%d %H:%M:%S')] Starting P2P-SAC SHARED-GPU job (ID: ${SLURM_JOB_ID}) on node ${SLURMD_NODENAME}."

# ------------------------------------------------------------------------------
# 1. Environment & Path Configuration
# ------------------------------------------------------------------------------
export ISAACLAB_ROOT="/mimer/NOBACKUP/groups/naiss2024-22-1645/Paper_CDC/IsaacLab"
export COMPASS_ROOT="${ISAACLAB_ROOT}/compass_algorithm"
export IL_ROOT="${ISAACLAB_ROOT}/compass_algorithm"

# Create log directory for SLURM outputs
mkdir -p "${ISAACLAB_ROOT}/slurm_logs"
cd "${ISAACLAB_ROOT}"

echo "[$(date '+%Y-%m-%d %H:%M:%S')] Loading Isaac Lab helpers..."
source "${COMPASS_ROOT}/isaac_helpers.sh"

# ------------------------------------------------------------------------------
# 2. RUN 1 (GPU 0 - Seed 42)
# ------------------------------------------------------------------------------
(
    # Point to the ONLY available GPU (0)
    export CUDA_VISIBLE_DEVICES=0
    export PORTABLE_ROOT="${COMPASS_ROOT}/kit_portable/job_${USER}_${SLURM_JOB_ID}_run1"

    # Strictly isolate the cache to prevent SQLite database locks
    mkdir -p "${PORTABLE_ROOT}/kit_cache"
    mkdir -p "${PORTABLE_ROOT}/kit_data"
    mkdir -p "${PORTABLE_ROOT}/kit_logs"
    mkdir -p "${PORTABLE_ROOT}/kit_documents"

    echo "[$(date '+%Y-%m-%d %H:%M:%S')] Launching Run 1 (Seed 42) on Shared GPU 0..."
    
    isaacrun compass_algorithm/train_compass_v2.py --headless \
        --algo compass \
        --seed 0 \
        --ablation_maturation none \
        --ablation_beta none \
        --num_envs 1 \
        --total_timesteps 50_000_000 \
        --video \
        --video_length 2_000 \
        --video_interval 100_000 \
        --anchor_weight 1.0 \
        --gate_tau 1.0 \
        --stationarity_tolerance 1e-3 \
        --patience_window 1_000 \
        --confidence_delta 0.01 \
        --loss_range_b 4.0 \
        --burn_in_steps 10_000 \
        --beta_min 0.9 \
        --use_3d_action \
        --max_steps 6_000 \
        --goal_reward 100.0 \
        --crash_cost 200.0 \
        --step_cost 1.0 \
        --w_progress 50.0 \
        --goal_tol 0.3 \
        --robot_radius 0.3 \
        --leg_reach_margin 0.02 \
        --wall_margin 0.35 \
        --planner_horizon 15 \
        --planner_max_vel 0.25 \
        --planner_barrier_beta 100.0 > "${ISAACLAB_ROOT}/slurm_logs/run1_shared_${SLURM_JOB_ID}.log" 2>&1
) & 


# ------------------------------------------------------------------------------
# 3. RUN 2 (GPU 0 - Seed 0)
# ------------------------------------------------------------------------------
(
    # Point to the EXACT SAME GPU (0)
    export CUDA_VISIBLE_DEVICES=0
    export PORTABLE_ROOT="${COMPASS_ROOT}/kit_portable/job_${USER}_${SLURM_JOB_ID}_run2"

    # Strictly isolate the cache from Run 1
    mkdir -p "${PORTABLE_ROOT}/kit_cache"
    mkdir -p "${PORTABLE_ROOT}/kit_data"
    mkdir -p "${PORTABLE_ROOT}/kit_logs"
    mkdir -p "${PORTABLE_ROOT}/kit_documents"

    echo "[$(date '+%Y-%m-%d %H:%M:%S')] Launching Run 2 (Seed 0) on Shared GPU 0..."
    
    # Optional: Wait 30 seconds before launching the second instance to prevent 
    # Omniverse startup routines from causing a race condition on the CPU.
    sleep 120 
    
    isaacrun compass_algorithm/train_compass_v2.py --headless \
        --algo compass \
        --seed 0 \
        --ablation_maturation none \
        --ablation_beta none \
        --num_envs 1 \
        --total_timesteps 50_000_000 \
        --video \
        --video_length 2_000 \
        --video_interval 100_000 \
        --anchor_weight 1.0 \
        --gate_tau 1.0 \
        --stationarity_tolerance 1e-3 \
        --patience_window 1_000 \
        --confidence_delta 0.01 \
        --loss_range_b 4.0 \
        --burn_in_steps 200_000 \
        --beta_min 0.9 \
        --use_3d_action \
        --max_steps 6_000 \
        --goal_reward 100.0 \
        --crash_cost 200.0 \
        --step_cost 1.0 \
        --w_progress 50.0 \
        --goal_tol 0.3 \
        --robot_radius 0.3 \
        --leg_reach_margin 0.02 \
        --wall_margin 0.35 \
        --planner_horizon 15 \
        --planner_max_vel 0.25 \
        --planner_barrier_beta 100.0 > "${ISAACLAB_ROOT}/slurm_logs/run2_shared_${SLURM_JOB_ID}.log" 2>&1
) & 


# ------------------------------------------------------------------------------
# 4. Wait for Completion
# ------------------------------------------------------------------------------
wait
echo "[$(date '+%Y-%m-%d %H:%M:%S')] Job ${SLURM_JOB_ID} completed successfully."