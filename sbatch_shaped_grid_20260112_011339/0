run_bg() {
  local OUT_FILE="$1"
  local ERR_FILE="$2"
  shift 2
  "$@" >"$OUT_FILE" 2>"$ERR_FILE" &
  pids+=("$!")
  if [ ${#pids[@]} -ge "$MAX_PARALLEL" ]; then
    echo ">> wait (batch of $MAX_PARALLEL)"
    for pid in "${pids[@]}"; do
      wait "$pid" || exit 1
    done
    pids=()
  fi
}


